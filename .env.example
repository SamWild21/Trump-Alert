# Full URL for a Truth Social API endpoint or feed proxy that returns the account's latest posts.
# The app accepts either an array of posts or an object containing statuses, posts, results, data, or items.
TRUTH_SOCIAL_SOURCE_URL=https://ix.cnn.io/data/truth-social/truth_archive.json

# Optional bearer token if your selected source needs one.
# TRUTH_SOCIAL_AUTH_TOKEN=

# Gmail SMTP settings.
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Optional display sender. Defaults to GMAIL_USER if omitted.
# EMAIL_FROM="Truth Social Monitor <your-gmail-address@gmail.com>"
EMAIL_TO=you@example.com

# Polling interval. Values below 30 seconds are rejected to avoid hammering the source.
POLL_INTERVAL_SECONDS=300

# Optional runtime settings.
PORT=3000
STATE_FILE=./data/state.json
SEND_INITIAL_ALERTS=false
